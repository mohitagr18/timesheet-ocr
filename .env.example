# Environment variables for timesheet-ocr
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control

# ── Cloud VLM API (used by layout_guided_vlm_cloud mode) ──
GOOGLE_API_KEY=your-google-api-key-here

# ── OpenAI (optional, not currently used) ──
OPENAI_API_KEY=your-openai-api-key-here

# ── Opik Observability (optional) ──
OPIK_API_KEY=your-opik-api-key-here
OPIK_PROJECT_NAME=timesheet-ocr
